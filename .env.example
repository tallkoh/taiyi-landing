# Gmail SMTP
# Enable App Passwords: myaccount.google.com/security → 2FA → App Passwords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Neon PostgreSQL
# Create a project at neon.tech, copy the connection string from the dashboard
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Run this once in the Neon SQL editor to create the subscribers table:
#
#   CREATE TABLE IF NOT EXISTS subscribers (
#     id         SERIAL PRIMARY KEY,
#     email      TEXT    NOT NULL,
#     type       TEXT    NOT NULL,
#     dob        TEXT,
#     tob        TEXT,
#     pob        TEXT,
#     created_at TIMESTAMPTZ NOT NULL DEFAULT now(),
#     UNIQUE(email, type)
#   );

# Stripe
# Secret key: Stripe Dashboard → Developers → API keys (sk_live_... for prod)
STRIPE_SECRET_KEY=sk_live_...

# Price ID: Stripe → Products → create "$12/mo" recurring price → copy price_...
STRIPE_PRICE_ID=price_...

# Production URL (no trailing slash) — used for Stripe redirect URLs
SITE_URL=https://taiyi.sg
