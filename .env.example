# Gmail SMTP
# Enable App Passwords: myaccount.google.com/security → 2FA → App Passwords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Neon PostgreSQL
# Create a project at neon.tech, copy the connection string from the dashboard
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Run the schema once against Neon (idempotent):
#   psql $DATABASE_URL -f db/schema.sql

# Stripe
# Secret key: Stripe Dashboard → Developers → API keys (sk_live_... for prod)
STRIPE_SECRET_KEY=sk_live_...

# Price ID: Stripe → Products → create "$18/mo" recurring price → copy price_...
STRIPE_PRICE_ID=price_...

# Webhook signing secret: Stripe → Developers → Webhooks → Add endpoint
#   URL:    https://taiyi.guru/api/stripe-webhook
#   Events: checkout.session.completed, customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# Production URL (no trailing slash) — used for Stripe redirect URLs
SITE_URL=https://taiyi.guru

# Cron auth — Vercel Cron sends this as `Authorization: Bearer ${CRON_SECRET}`
# Generate with:  openssl rand -hex 32
CRON_SECRET=replace_with_long_random_string
