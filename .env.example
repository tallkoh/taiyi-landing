# Mailchimp
# API key: Mailchimp Dashboard → Account → Extras → API keys
# Format: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us21  (suffix = datacenter)
MAILCHIMP_API_KEY=

# Audience ID: Mailchimp Dashboard → Audience → Settings → Audience name and defaults
MAILCHIMP_LIST_ID=

# Stripe
# Secret key: Stripe Dashboard → Developers → API keys
# Use sk_test_... for testing, sk_live_... for production
STRIPE_SECRET_KEY=

# Price ID: Stripe Dashboard → Products → create a recurring $12/mo product → copy Price ID
# Format: price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID=

# Production URL (no trailing slash) — used for Stripe success/cancel redirect URLs
# Example: https://taiyi.sg
SITE_URL=
